{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 80,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "arrowParens": "always",
  "bracketSpacing": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "dist-electron",
    "dist-ssr",
    "coverage",
    "build",
    "release",
    "resources",
    "pnpm-lock.yaml",
    "package-lock.json",
    ".vite",
    ".vscode"
  ]
}

{
  "name": "selectively-crawl-web-content",
  "version": "2.0.0",
  "description": "A web extension for selectively crawling web content.",
  "bugs": {
    "url": "https://github.com/XunJiJinag/selectively-crawl-web-content/issues"
  },
  "author": "XunJi & XunJiJiang",
  "repository": {
    "type": "git",
    "url": "https://github.com/XunJiJinag/selectively-crawl-web-content"
  },
  "workspaces": [
    "projects/*"
  ],
  "type": "module",
  "scripts": {
    "dev:server": "node projects/server/scripts/setup.ts --mode=dev --web-port=3201",
    "prod:server": "node projects/server/scripts/setup.ts --mode=prod",
    "dev:us": "cd projects/user-script && bun run dev",
    "dev:web": "cd projects/web && bun run dev",
    "build": "tsc -b && cd projects/user-script && bun run build && cd ../web && bun run build && cd ../webutils && bun run build",
    "test": "vitest",
    "lint": "oxlint",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@lit/context": "^1.1.6",
    "@types/express": "^5.0.6",
    "axios": "^1.18.1",
    "better-sqlite3": "^13.0.1",
    "cache-manager": "^7.2.9",
    "cacheable": "^2.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.49.0",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "jsdom": "^29.1.1",
    "keyv": "^5.6.0",
    "lit": "^3.3.3",
    "open": "^11.0.0",
    "opencc-js": "^1.4.1",
    "proxy-agent": "^8.0.2",
    "reflect-metadata": "^0.2.2",
    "trash": "^10.1.1",
    "tsx": "^4.23.1",
    "url-change-event": "^0.1.7",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@oxlint/migrate": "^1.75.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/opencc-js": "^1.0.3",
    "globals": "^17.7.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-monkey": "^8.1.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {},
  "engines": {
    "node": "^24"
  }
}
